# Paste the full "Copy as cURL" command from account 1 here.
# DevTools → Network → filter "conversations" → right click → Copy → Copy as cURL
#
# Rename this file to: source.curl
#   cp secrets/source.curl.example secrets/source.curl
#
# Example shape (DO NOT commit real tokens):
#
# curl 'https://chatgpt.com/backend-api/conversations?offset=0&limit=28&order=updated' \
#   -H 'authorization: Bearer eyJ...' \
#   -H 'cookie: __Secure-next-auth.session-token=...; ...' \
#   -H 'oai-device-id: ...' \
#   -H 'user-agent: Mozilla/5.0 ...'
