# Account 2 cookies — pick ONE format, then rename to target.cookies
#
# Option A — Cookie header line (easiest):
# DevTools → Network → any chatgpt.com request → Request Headers → cookie
# Paste the whole value on one line (no "cookie:" prefix needed):
#
# __Secure-next-auth.session-token=...; __cf_bm=...; oai-did=...; ...
#
# Option B — Playwright JSON array:
# [
#   {
#     "name": "__Secure-next-auth.session-token",
#     "value": "...",
#     "domain": ".chatgpt.com",
#     "path": "/",
#     "secure": true,
#     "httpOnly": true,
#     "sameSite": "Lax"
#   }
# ]
#
# cp secrets/target.cookies.example secrets/target.cookies
